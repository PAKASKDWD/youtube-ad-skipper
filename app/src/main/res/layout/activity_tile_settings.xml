<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_surface"
    android:padding="24dp">

    <!-- 헤더 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="빠른 설정"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/md_on_surface"
        android:layout_marginBottom="32dp" />

    <!-- 접근성 서비스 상태 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_stat_card"
        android:padding="20dp"
        android:orientation="vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="접근성 서비스"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/md_on_surface_muted"
            android:textAllCaps="true"
            android:letterSpacing="0.04" />

        <TextView
            android:id="@+id/accessibilityStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="접근성 서비스: 확인 중..."
            android:textSize="16sp"
            android:textColor="@color/md_on_surface" />

        <Button
            android:id="@+id/btnAccessibility"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="접근성 설정 열기"
            android:textSize="14sp"
            android:backgroundTint="@color/md_surface_container_high"
            android:textColor="@color/md_on_surface" />
    </LinearLayout>

    <!-- 자동 스킵 ON/OFF -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_stat_card"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="자동 스킵"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/md_on_surface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="광고 건너뛰기 버튼 자동 클릭"
                android:textSize="13sp"
                android:textColor="@color/md_on_surface_muted" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/skipToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 닫기 -->
    <Button
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="닫기"
        android:textSize="15sp"
        android:backgroundTint="@color/md_surface_container_high"
        android:textColor="@color/md_on_surface" />

</LinearLayout>
