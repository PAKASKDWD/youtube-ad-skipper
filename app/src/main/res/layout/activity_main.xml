<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_surface"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YouTube Ad Skipper"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_on_surface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v1.0 · 오픈소스"
                    android:textSize="12sp"
                    android:textColor="@color/md_on_surface_muted" />
            </LinearLayout>
        </LinearLayout>

        <!-- Hero Card -->
        <LinearLayout
            android:id="@+id/heroCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/bg_hero_card">

            <!-- Status Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <View
                    android:id="@+id/statusDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_live" />

                <TextView
                    android:id="@+id/statusLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="활성화 중"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/live" />
            </LinearLayout>

            <!-- Hero Text -->
            <TextView
                android:id="@+id/heroTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="광고를 자동으로\n스킵하고 있어요."
                android:textSize="28sp"
                android:textColor="@color/md_on_surface"
                android:lineSpacingMultiplier="1.15" />

            <TextView
                android:id="@+id/heroSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/hero_subtitle_active"
                android:textSize="14sp"
                android:textColor="@color/md_on_surface_variant"
                android:lineSpacingMultiplier="1.45" />

            <!-- Toggle Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_toggle_row"
                android:gravity="center_vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="자동 스킵 서비스"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/md_on_surface" />

                    <TextView
                        android:id="@+id/toggleSubtext"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="실행 중 · 데이터 사용 없음"
                        android:textSize="12sp"
                        android:textColor="@color/md_on_surface_muted" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnOpenSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="설정 열기"
                    android:textSize="13sp"
                    android:backgroundTint="@color/accent"
                    android:textColor="@color/white" />
            </LinearLayout>
        </LinearLayout>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp"
            android:orientation="horizontal">

            <!-- Today Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="@drawable/bg_stat_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="오늘"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent"
                    android:textAllCaps="true"
                    android:letterSpacing="0.04" />

                <TextView
                    android:id="@+id/todayCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="0"
                    android:textSize="40sp"
                    android:textColor="@color/md_on_surface"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="개 스킵"
                    android:textSize="13sp"
                    android:textColor="@color/md_on_surface_variant" />
            </LinearLayout>

            <!-- Total Saved Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="@drawable/bg_stat_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="총 절약 시간"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_on_surface_muted"
                    android:textAllCaps="true"
                    android:letterSpacing="0.04" />

                <TextView
                    android:id="@+id/totalSavedText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="0:00"
                    android:textSize="40sp"
                    android:textColor="@color/md_on_surface"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/totalSavedUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="분"
                    android:textSize="13sp"
                    android:textColor="@color/md_on_surface_variant" />
            </LinearLayout>
        </LinearLayout>

        <!-- Week Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="16dp"
            android:orientation="vertical"
            android:padding="22dp"
            android:background="@drawable/bg_stat_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이번 주 스킵"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/md_on_surface_muted"
                android:textAllCaps="true"
                android:letterSpacing="0.04" />

            <TextView
                android:id="@+id/weekCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="0개 스킵"
                android:textSize="32sp"
                android:textColor="@color/md_on_surface"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Privacy Footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="16dp"
            android:orientation="horizontal"
            android:padding="14dp"
            android:background="@drawable/bg_footer"
            android:gravity="top">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/privacy_footer"
                android:textSize="12sp"
                android:textColor="@color/md_on_surface_muted"
                android:lineSpacingMultiplier="1.55" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
