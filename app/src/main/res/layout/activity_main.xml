<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="YouTube Ad Skipper"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="서비스 비활성화 상태"
        android:textSize="16sp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnOpenSettings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="접근성 설정 열기"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/todayCountText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="오늘: 0개 스킵"
        android:textSize="18sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/weekCountText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="이번 주: 0개 스킵"
        android:textSize="18sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/totalSavedText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="총 절약 시간: 0초"
        android:textSize="18sp" />

</LinearLayout>
